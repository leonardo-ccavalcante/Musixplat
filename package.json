{
  "name": "musixmatch-customer-ops",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "concurrently -n client,server -c blue,green \"pnpm dev:client\" \"pnpm dev:server\"",
    "dev:client": "vite",
    "dev:server": "tsx watch server/index.ts",
    "start": "node dist/server/server/index.js",
    "build": "pnpm typecheck && vite build && tsc -p tsconfig.server.json",
    "preview": "vite preview",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run --project unit",
    "test:watch": "vitest",
    "test:antifake": "vitest run --project antifake",
    "test:integration": "vitest run --project integration --fileParallelism=false",
    "test:sql": "supabase db reset && supabase test db",
    "test:e2e": "playwright test",
    "test:a11y": "playwright test --grep @a11y",
    "db:start": "supabase start",
    "db:stop": "supabase stop",
    "db:reset": "supabase db reset",
    "db:seed": "supabase db reset",
    "db:push": "supabase db push",
    "db:migration": "supabase migration new",
    "db:p01": "tsx scripts/run-p01.ts",
    "db:p02": "tsx scripts/run-p02.ts",
    "db:05b": "tsx scripts/run-05b.ts",
    "db:migrate": "tsx scripts/apply-migrations.ts",
    "prototype:reset": "tsx scripts/prototype-reset.ts",
    "prototype:check": "tsx scripts/prototype-check.ts",
    "ci": "pnpm lint && pnpm typecheck && pnpm test && pnpm test:sql && pnpm test:antifake && pnpm test:integration"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.2",
    "@supabase/supabase-js": "^2.45.4",
    "@tanstack/react-query": "^5.59.0",
    "@trpc/client": "^11.0.0-rc.553",
    "@trpc/react-query": "^11.0.0-rc.553",
    "@trpc/server": "^11.0.0-rc.553",
    "@xstate/react": "^5.0.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "cookie": "^1.0.1",
    "express": "^4.21.0",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.451.0",
    "pg": "^8.13.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "superjson": "^2.2.1",
    "tailwind-merge": "^2.5.4",
    "unpdf": "^1.6.2",
    "wouter": "^3.3.5",
    "xstate": "^5.18.2",
    "zod": "^3.23.8",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.0",
    "@eslint/js": "^9.12.0",
    "@playwright/test": "^1.48.0",
    "@testing-library/jest-dom": "^6.5.0",
    "@testing-library/react": "^16.0.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.7.4",
    "@types/pg": "^8.11.10",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.2",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.0.1",
    "dotenv": "^16.4.5",
    "eslint": "^9.12.0",
    "globals": "^15.10.0",
    "jsdom": "^25.0.1",
    "postcss": "^8.4.47",
    "supabase": "^1.207.9",
    "tailwindcss": "^3.4.13",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "typescript-eslint": "^8.8.0",
    "vite": "^7.0.0",
    "vitest": "^3.2.4"
  }
}
