# Musixmatch Customer-Ops — environment template.
# Copy to .env.local and fill in. NEVER commit .env.local. Secrets live in deploy secrets only.
# CLAUDE.md §6: reference env-var NAMES in code, never the value. This template carries NO real values.

# ─── Frontend (Vite, public) ─────────────────────────────────────────────────
VITE_SUPABASE_URL=            # https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=       # Supabase anon key (public, RLS-protected). Fill in .env.local.
VITE_APP_ID=                  # Manus OAuth app id (Manus dashboard → OAuth apps)
VITE_OAUTH_PORTAL_URL=        # OAuth callback portal (prod: https://oauth.manus.im)

# ─── Server / tRPC ───────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
APP_URL=                      # public app URL (webhook payloads + links)
JWT_SECRET=                   # REQUIRED in prod — server refuses to boot if empty. Generate a random secret.

# ─── Supabase service role (SERVER-ONLY — never expose to the client) ─────────
SUPABASE_URL=                 # https://<project-ref>.supabase.co (same project, server side)
SUPABASE_SERVICE_ROLE_KEY=    # service role key — server tRPC procedures only, NEVER browser code. Fill in .env.local.

# ─── Manus OAuth + Forge (deploy/auth layer) ─────────────────────────────────
OAUTH_SERVER_URL=             # Manus OAuth server (prod: https://oauth.manus.im)
OWNER_OPEN_ID=                # Manus owner open id
BUILT_IN_FORGE_API_URL=       # Manus Forge API (empty ⇒ Forge features disabled)
BUILT_IN_FORGE_API_KEY=
DATABASE_URL=                 # Supabase Postgres connection (server pg pool + tests). Local: postgresql://postgres:postgres@127.0.0.1:54522/postgres

# ─── AGENTE / N8N layer (LLM pieces; see breakdown_N8N.md) ────────────────────
N8N_WEBHOOK_URL=              # n8n container webhook base
N8N_API_KEY=                  # n8n API key

# ─── Optional ────────────────────────────────────────────────────────────────
RLS_TESTS_ENABLED=            # "1" to run RLS integration tests in CI once seeded auth users exist

# ─── OpenAI (single LLM vendor) ───────────────────────────────────────────────
# Powers BOTH embeddings (text-embedding-3-small, Knowledge Base RAG) AND the chat LLM
# (gpt-4o-mini: doc-type classify + diagnosis classify/rank — text only, never a number, §3.6/§8).
# Empty → deterministic fallback everywhere (CI stays hermetic + free).
OPENAI_API_KEY=
