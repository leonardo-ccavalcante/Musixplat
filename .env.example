# Musixmatch Customer-Ops — environment template.
# Copy to .env.local and fill in. NEVER commit .env.local. Secrets live in deploy secrets only.
# CLAUDE.md §6: reference env-var NAMES in code, never the value.

# ─── Frontend (Vite, public) ─────────────────────────────────────────────────
VITE_SUPABASE_URL=https://eomyxhycaefuueshvwih.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImVvbXl4aHljYWVmdXVlc2h2d2loIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODE3MjIzODUsImV4cCI6MjA5NzI5ODM4NX0.ASwbcRSAxqwRAGhqYlNesclP6hevG7WTEu0rnyTaFlA
VITE_APP_ID=                  # Manus OAuth app id (Manus dashboard → OAuth apps)
VITE_OAUTH_PORTAL_URL=        # OAuth callback portal (prod: https://oauth.manus.im)

# ─── Server / tRPC ───────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
APP_URL=                      # public app URL (webhook payloads + links)
JWT_SECRET= 502fa828-83d8-4cd9-9cd0-5296547d6d39
                              # REQUIRED in prod — server refuses to boot if empty.

# ─── Supabase service role (SERVER-ONLY — never expose to the client) ─────────
SUPABASE_URL=https://eomyxhycaefuueshvwih.supabase.co               # same project URL, server side
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImVvbXl4aHljYWVmdXVlc2h2d2loIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTc4MTcyMjM4NSwiZXhwIjoyMDk3Mjk4Mzg1fQ.PF3NNYIIZMjMNa5R9OAUXnM2r7GJtEaJ-FolH_ncqVU    # service role key; used only by server tRPC procedures, never browser code

# ─── Manus OAuth + Forge (deploy/auth layer) ─────────────────────────────────
OAUTH_SERVER_URL=             # Manus OAuth server (prod: https://oauth.manus.im)
OWNER_OPEN_ID=                # Manus owner open id
BUILT_IN_FORGE_API_URL=       # Manus Forge API (empty ⇒ Forge features disabled)
BUILT_IN_FORGE_API_KEY=
DATABASE_URL=                 # MySQL (drizzle-orm) holding Manus OAuth users ONLY. App data is Supabase, never this.

# ─── AGENTE / N8N layer (LLM pieces; see breakdown_N8N.md) ────────────────────
ANTHROPIC_API_KEY=            # LLM for AGENTE pieces (synthesis/ranking — text only, never numbers, CLAUDE.md §8)
N8N_WEBHOOK_URL=              # n8n container webhook base
N8N_API_KEY=                  # n8n API key

# ─── Optional ────────────────────────────────────────────────────────────────
RLS_TESTS_ENABLED=            # "1" to run RLS integration tests in CI once seeded auth users exist
