# Musixmatch Customer-Ops — environment template.
# Copy to .env.local and fill in. NEVER commit .env.local. Secrets live in deploy secrets only.
# CLAUDE.md §6: reference env-var NAMES in code, never the value. This template carries NO real values.
#
# This is the COMPLETE surface the code reads. (The old Manus/Forge/Supabase-anon/n8n vars were removed —
# they were never read; the app deploys to Railway with demo dev-login, not Manus OAuth.)

# ─── Server ──────────────────────────────────────────────────────────────────
NODE_ENV=development           # "production" on the deploy — gates the demo login + the fail-closed secrets below
PORT=3000                      # server port (Railway injects its own)

# ─── Required in PRODUCTION ──────────────────────────────────────────────────
# assertProdSecrets() (server/_core/env.ts) refuses to boot in production if any of these is empty or a
# dev default — so a misconfigured deploy fails fast at boot, not mid-request.
DATABASE_URL=                  # Postgres connection (server pg pool + tests).
                               # Local default if empty: postgresql://postgres:postgres@127.0.0.1:54522/postgres
JWT_SECRET=                    # session cookie HS256 secret. Generate a long random value.
OPENAI_API_KEY=                # OpenAI: embeddings (text-embedding-3-small, KB RAG) + chat (gpt-4o-mini —
                               # classify/rank, text only, never a number, §3.6/§8). Required in prod.
AGENT_GATEWAY_TOKEN=           # Bearer token the channel relay (n8n) sends to POST /api/chat. Generate a
                               # long random value; must match the n8n httpHeaderAuth credential. Required in prod.

# ─── Demo deploy ─────────────────────────────────────────────────────────────
DEMO_LOGIN=                    # set "1" on a public/demo deploy to enable /auth/dev-login in production
                               # (auto-logs in the seeded operator). WITHOUT it, production returns 404 on
                               # login and every screen is blank. Leave empty for local dev (login is
                               # always on when NODE_ENV != production).
                               # ⚠️ SECURITY: with DEMO_LOGIN=1 ANY visitor gets a senior-manager session
                               # (write access: uploadConfig, autonomy controls). Use ONLY on a disposable
                               # demo DB — NEVER on a deploy holding real data.
